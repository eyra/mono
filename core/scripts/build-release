#!/bin/bash
# DEPRECATED: the use of this script is no longer recommended.

set -e
set -x

if [ -z ${VERSION} ]; then
    echo "VERSION is unset"
    exit 1
fi
if [ -z ${BUNDLE} ]; then
    echo "BUNDLE is unset"
    exit 1
fi

cd $(dirname "$0")/..

# Copy platform-specific runtime config
if [ -f "config/runtime.${PLATFORM}.exs" ]; then
  echo "Using runtime config for platform: ${PLATFORM}"
  cp "config/runtime.${PLATFORM}.exs" config/runtime.exs
else
  echo "WARNING: No runtime config found for platform: ${PLATFORM}"
fi

mix deps.get
mix assets.setup
mix assets.deploy

MIX_ENV=prod mix release --overwrite --path "${VERSION}"

chmod -R a+rX "${VERSION}"
